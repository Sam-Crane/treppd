# =============================================================================
# TREPPD Environment Variables
# Copy this file to .env and fill in the values from the team Notion vault
# =============================================================================

# Supabase (EU Frankfurt region)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
SUPABASE_JWT_SECRET=your-jwt-secret

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-your-key

# Voyage AI (embeddings for RAG chat) — sign up at voyageai.com
# Free tier: 200M free tokens for voyage-3, but rate limits depend on whether
# you've added a payment method:
#   - WITHOUT payment method: 3 RPM (10K TPM) — set VOYAGE_FREE_TIER=1 below
#     so the ingester paces requests to one chunk per 22 seconds
#   - WITH payment method: 2000 RPM — leave VOYAGE_FREE_TIER unset for fast batched ingestion
# Adding a payment method does NOT charge until you exceed 200M tokens
# (we use ~50K total for ingestion + ~10/query).
VOYAGE_API_KEY=pa-your-voyage-key
VOYAGE_FREE_TIER=1

# Internal Service Communication
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=generate-a-random-32-char-string

# Redis
REDIS_URL=redis://localhost:6379

# Firebase Cloud Messaging (for push notifications)
FCM_SERVER_KEY=your-fcm-server-key

# JWT (fallback — prefer Supabase JWT)
JWT_SECRET=generate-a-random-64-char-string

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
