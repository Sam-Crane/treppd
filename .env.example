# =============================================================================
# TREPPD Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit real secrets — only placeholders belong here.
# =============================================================================

# Supabase (EU Frankfurt region)
# Project URL is not a secret (it ships in the frontend bundle).
SUPABASE_URL=https://your-project.supabase.co

# Publishable key (formerly "anon key"). Used by the web frontend.
# Prefix: sb_publishable_... — safe to expose, protected server-side by RLS.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Secret key (formerly "service_role key"). Server-side ONLY — bypasses RLS.
# Prefix: sb_secret_... — must NEVER appear in client bundles or this file.
SUPABASE_SECRET_KEY=sb_secret_your-key

# Postgres connection string (includes DB password).
SUPABASE_DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Note: no SUPABASE_JWT_SECRET. Supabase now signs tokens with an asymmetric
# ECC P-256 key; the NestJS guard verifies them against the project's JWKS
# endpoint (derived from SUPABASE_URL). No shared secret needed.

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-your-key

# Voyage AI (embeddings for RAG chat) — sign up at voyageai.com
# Free tier: 200M free tokens for voyage-3, but rate limits depend on whether
# you've added a payment method:
#   - WITHOUT payment method: 3 RPM (10K TPM) — set VOYAGE_FREE_TIER=1 below
#     so the ingester paces requests to one chunk per 22 seconds
#   - WITH payment method: 2000 RPM — leave VOYAGE_FREE_TIER unset for fast batched ingestion
# Adding a payment method does NOT charge until you exceed 200M tokens
# (we use ~50K total for ingestion + ~10/query).
VOYAGE_API_KEY=pa-your-voyage-key
VOYAGE_FREE_TIER=1

# Internal Service Communication
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=generate-a-random-32-char-string

# Redis
REDIS_URL=redis://localhost:6379

# Firebase Cloud Messaging (for push notifications)
FCM_SERVER_KEY=your-fcm-server-key

# Web Push / VAPID (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:hello@treppd.de
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# JWT (fallback — prefer Supabase JWT)
JWT_SECRET=generate-a-random-64-char-string

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
